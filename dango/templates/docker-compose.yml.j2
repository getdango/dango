services:
  # Metabase - BI Dashboards
  metabase:
    # Build custom Debian-based image for DuckDB compatibility (needs glibc/libstdc++)
    # Standard Metabase images use Alpine which lacks required libraries
    build:
      context: .
      dockerfile: Dockerfile.metabase
    ports:
      - "127.0.0.1:{{ metabase_port }}:3000"
    volumes:
      - metabase-data:/metabase-data
      # :ro prevents Metabase JDBC driver from acquiring DuckDB write lock.
      # The driver ignores read_only config; filesystem-level :ro is required.
      - ./data:/data:ro
      - ./metabase-plugins:/app/plugins
    environment:
      MB_DB_TYPE: h2
      MB_DB_FILE: /metabase-data/metabase.db
      MB_SITE_NAME: "{{ project_name }}"
      MB_ENABLE_PUBLIC_SHARING: false
      MB_ANON_TRACKING_ENABLED: false
      MB_PLUGINS_DIR: /app/plugins
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 300s
    restart: unless-stopped

  # dbt Docs - Documentation Server
  dbt-docs:
    image: nginx:alpine
    ports:
      - "127.0.0.1:{{ dbt_docs_port }}:80"
    volumes:
      - ./dbt/target:/usr/share/nginx/html:ro
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

volumes:
  metabase-data:
    driver: local
